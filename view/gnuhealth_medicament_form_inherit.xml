<?xml version="1.0"?>
<data>
    <xpath expr="/form/group[@id='medicament_presentation']" position="replace">
        <group colspan="4" col="8" string="Principal" id="medicament_presentation">
            <label name="name"/>
            <field name="name" colspan="3"/>
            <label name="active_component"/>
            <field name="active_component" colspan="3"/>

            <label name="strength"/>
            <field name="strength"/>
            <label name="unit"/>
            <field name="unit"/>
            <label name="form"/>
            <field name="form"/>
            <label name="route"/>
            <field name="route"/>

            <label name="category"/>
            <field name="category" colspan="3"/>

            <separator string="Solucion" colspan="8" id="medicament_solution_separator"/>

            <label name="sol_conc"/>
            <field name="sol_conc"/>
            <label name="sol_conc_unit"/>
            <field name="sol_conc_unit"/>
            <label name="sol_vol"/>
            <field name="sol_vol"/>
            <label name="sol_vol_unit"/>
            <field name="sol_vol_unit"/>
        </group>
    </xpath>
</data>
