<?xml version="1.0"?>
<data>
    <xpath expr="/form/group[@id='medicament_presentation']" position="replace">
        <group colspan="4" col="4" string="Principal" id="medicament_presentation">
            <group colspan="4" col="4" id="medicament_identification">
                <label name="name"/>
                <field name="name" colspan="3"/>
                <label name="active_component"/>
                <field name="active_component" colspan="3"/>
            </group>

            <group colspan="4" col="4" id="medicament_core_details">
                <label name="strength"/>
                <group col="2" colspan="1" id="medicament_strength_pair">
                    <field name="strength"/>
                    <field name="unit"/>
                </group>
                <label name="form"/>
                <field name="form"/>
                <label name="route"/>
                <field name="route"/>
                <label name="category"/>
                <field name="category"/>
            </group>

            <separator string="Solución" colspan="4" id="medicament_solution_separator"/>
            <group colspan="4" col="4" id="medicament_concentration">
                <label name="sol_conc"/>
                <group col="2" colspan="1" id="medicament_solution_concentration_pair">
                    <field name="sol_conc"/>
                    <field name="sol_conc_unit"/>
                </group>
                <label name="sol_vol"/>
                <group col="2" colspan="1" id="medicament_solution_volume_pair">
                    <field name="sol_vol"/>
                    <field name="sol_vol_unit"/>
                </group>
            </group>
        </group>
    </xpath>
</data>
